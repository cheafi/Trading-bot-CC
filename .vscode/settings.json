// Place your settings in this file to overwrite default and user settings.
{
	// ── File visibility ──────────────────────────────────────────────────────
	"files.exclude": {
		"out": false, // set this to true to hide the "out" folder with the compiled JS files
		"dist": false, // set this to true to hide the "dist" folder with the compiled JS files
		"**/__pycache__": true,
		"**/*.pyc": true,
		"**/.mypy_cache": true,
		"**/.ruff_cache": true,
		"**/.pytest_cache": true,
		"**/.omg": true
	},
	"search.exclude": {
		"out": true, // set this to false to include "out" folder in search results
		"dist": true, // set this to false to include "dist" folder in search results
		"**/venv": true,
		"**/.venv": true,
		"**/__pycache__": true,
		"**/backup_untracked": true,
		"**/data/artifacts": true,
		"**/data/experiments": true,
		"**/plans": true,
		"**/.mypy_cache": true,
		"**/.ruff_cache": true,
		"**/.pytest_cache": true,
		"**/locales": true,
		"pnpm-lock.yaml": true
	},

	// ── Performance: watcher exclusions ──────────────────────────────────────
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/out/**": true,
		"**/__pycache__/**": true,
		"**/*.pyc": true,
		"**/venv/**": true,
		"**/.venv/**": true,
		"**/data/**": true,
		"**/backup_untracked/**": true,
		"**/plans/**": true,
		"**/locales/**": true,
		"**/.mypy_cache/**": true,
		"**/.ruff_cache/**": true,
		"**/.pytest_cache/**": true
	},

	// ── Git performance (large history from monorepo merge) ───────────────────
	// Disable VS Code's built-in git to prevent background `git status` hanging
	// on this 4000-file monorepo. Use terminal for git operations instead.
	"git.enabled": false,
	"git.autoRepositoryDetection": false,
	"git.decorations.enabled": false,
	"git.untrackedChanges": "separate",
	"scm.diffDecorations": "none",

	// ── Python / Pylance ─────────────────────────────────────────────────────
	// Limit analysis to src/ — prevents Pylance indexing 30× test_sprint*.py files
	"python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
	"python.analysis.include": ["src/**"],
	"python.analysis.exclude": [
		"**/node_modules/**",
		"**/venv/**",
		"**/.venv/**",
		"**/backup_untracked/**",
		"**/locales/**"
	],
	"python.analysis.packageIndexDepths": [{ "name": "", "depth": 2 }],

	// ── Copilot: skip completions in noise files ──────────────────────────────
	"github.copilot.enable": {
		"*": true,
		"plaintext": false,
		"markdown": false,
		"json": false
	},

	// ── Performance: disable heavy UI features ────────────────────────────────
	"editor.minimap.enabled": false,
	"editor.codeLens": false,
	"telemetry.telemetryLevel": "off",
	"extensions.autoUpdate": false,
	"workbench.enableExperiments": false,

	// ── Editor productivity ───────────────────────────────────────────────────
	"editor.formatOnSave": true,
	"editor.formatOnPaste": false,
	"editor.suggest.preview": true,
	"editor.acceptSuggestionOnEnter": "smart",

	// ── TypeScript ────────────────────────────────────────────────────────────
	// Turn off tsc task auto detection since we have the necessary tasks as npm scripts
	"typescript.tsc.autoDetect": "off",

	// ── Misc workspace ────────────────────────────────────────────────────────
	"vitest.disableWorkspaceWarning": true,
	"explorer.openEditors.sortOrder": "fullPath",

	// ── Terminal: skip-shell commands ─────────────────────────────────────────
	// quickOpen handled by VS Code, not passed to shell
	"terminal.integrated.commandsToSkipShell": ["workbench.action.quickOpen"],

	// ── Terminal: shell aliases (macOS zsh) ───────────────────────────────────
	"terminal.integrated.profiles.osx": {
		"zsh": {
			"path": "zsh",
			"args": ["-l"],
			"env": {}
		}
	},
	"terminal.integrated.defaultProfile.osx": "zsh"
}
