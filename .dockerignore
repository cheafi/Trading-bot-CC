# Ignore common development files
node_modules
.git
.gitignore
.dockerignore
.env*
.vscode
.idea

# Ignore build artifacts
dist
build
*.log
*.tmp
.cache
coverage

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test files
__tests__
*.test.js
*.spec.js
