"""
TradingAI Bot - Discord Interactive Bot

Full-featured Discord bot for trading signals and portfolio management.
Supports:
- Slash commands for stock analysis, signals, portfolio
- Real-time signal push notifications with embeds
- Interactive buttons for trade execution
- Voice channel alerts for high-priority signals
"""
import asyncio
import logging
from datetime import datetime, timezone
from typing import Any, Dict, List, Optional

import aiohttp

from src.core.config import get_settings

logger = logging.getLogger(__name__)
settings = get_settings()


class DiscordEmbed:
    """Discord rich embed builder."""

    def __init__(self, title: str = "", description: str = "", color: int = 0x2F3136):
        self.data: Dict[str, Any] = {
            "title": title,
            "description": description,
            "color": color,
            "fields": [],
            "timestamp": datetime.now(timezone.utc).isoformat(),
        }

    def add_field(self, name: str, value: str, inline: bool = True) -> "DiscordEmbed":
        self.data["fields"].append({"name": name, "value": value, "inline": inline})
        return self

    def set_footer(self, text: str) -> "DiscordEmbed":
        self.data["footer"] = {"text": text}
        return self

    def set_thumbnail(self, url: str) -> "DiscordEmbed":
        self.data["thumbnail"] = {"url": url}
        return self

    def to_dict(self) -> Dict[str, Any]:
        return self.data


class DiscordInteractiveBot:
    """
    Interactive Discord bot with webhook + bot token support.
    
    Webhook mode: Push-only (signals, alerts, reports)
    Bot mode: Full interactive commands (requires discord.py)
    """

    # Color palette
    COLOR_BUY = 0x00C853    # Green
    COLOR_SELL = 0xFF1744   # Red
    COLOR_INFO = 0x2979FF   # Blue
    COLOR_WARN = 0xFFAB00   # Amber
    COLOR_GOLD = 0xFFD600   # Gold for high confidence

    def __init__(self):
        self.webhook_url = settings.discord_webhook_url
        self.bot_token = getattr(settings, "discord_bot_token", None)
        self.logger = logging.getLogger(__name__)
        self._session: Optional[aiohttp.ClientSession] = None

    @property
    def is_configured(self) -> bool:
        return bool(self.webhook_url or self.bot_token)

    async def _get_session(self) -> aiohttp.ClientSession:
        if self._session is None or self._session.closed:
            self._session = aiohttp.ClientSession()
        return self._session

    async def close(self):
        if self._session and not self._session.closed:
            await self._session.close()

    # ------------------------------------------------------------------
    # Webhook-based push notifications
    # ------------------------------------------------------------------

    async def send_webhook(self, content: str = "", embeds: Optional[List[Dict]] = None) -> bool:
        if not self.webhook_url:
            return False
        session = await self._get_session()
        payload: Dict[str, Any] = {}
        if content:
            payload["content"] = content
        if embeds:
            payload["embeds"] = embeds[:10]  # Discord limit
        try:
            async with session.post(self.webhook_url, json=payload) as resp:
                if resp.status not in (200, 204):
                    body = await resp.text()
                    self.logger.error(f"Discord webhook {resp.status}: {body[:200]}")
                    return False
            return True
        except Exception as e:
            self.logger.error(f"Discord webhook error: {e}")
            return False

    # ------------------------------------------------------------------
    # Signal formatting
    # ------------------------------------------------------------------

    def format_signal_embed(self, signal: Any) -> Dict[str, Any]:
        """Create a rich embed for a trading signal."""
        direction = getattr(signal, "direction", None)
        is_buy = str(direction).upper() in ("LONG", "BUY")
        color = self.COLOR_BUY if is_buy else self.COLOR_SELL
        conf = getattr(signal, "confidence", 0)
        if conf >= 80:
            color = self.COLOR_GOLD

        arrow = "🟢 LONG" if is_buy else "🔴 SHORT"
        ticker = getattr(signal, "ticker", "???")

        embed = DiscordEmbed(
            title=f"{arrow} — {ticker}",
            description=getattr(signal, "entry_logic", ""),
            color=color,
        )

        embed.add_field("Entry", f"${getattr(signal, 'entry_price', 0):.2f}")
        embed.add_field("Confidence", f"{conf}%")
        embed.add_field("Horizon", str(getattr(signal, "horizon", "")))

        # Targets
        targets = getattr(signal, "targets", [])
        if targets:
            targets_str = " → ".join(
                f"${t.price:.2f} ({t.pct_position}%)" for t in targets
            )
            embed.add_field("🎯 Targets", targets_str, inline=False)

        # Stop
        inv = getattr(signal, "invalidation", None)
        if inv:
            embed.add_field("🛑 Stop", f"${inv.stop_price:.2f} ({inv.stop_type.value})")

        # R:R
        rr = getattr(signal, "risk_reward_ratio", None)
        if rr:
            embed.add_field("R:R", f"{rr:.1f}:1")

        # Strategy
        strat = getattr(signal, "strategy_id", None)
        if strat:
            embed.add_field("Strategy", strat)

        # Risks
        risks = getattr(signal, "key_risks", [])
        if risks:
            embed.add_field("⚠️ Risks", "\n".join(f"• {r}" for r in risks[:3]), inline=False)

        embed.set_footer(f"TradingAI Bot • {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}")
        return embed.to_dict()

    async def push_signal(self, signal: Any) -> bool:
        embed = self.format_signal_embed(signal)
        return await self.send_webhook(embeds=[embed])

    async def push_signals_batch(self, signals: List[Any]) -> int:
        """Push up to 10 signals in a single message."""
        if not signals:
            return 0
        embeds = [self.format_signal_embed(s) for s in signals[:10]]
        ok = await self.send_webhook(
            content=f"📊 **{len(signals)} New Signal{'s' if len(signals) > 1 else ''}**",
            embeds=embeds,
        )
        return len(signals) if ok else 0

    # ------------------------------------------------------------------
    # Portfolio & report embeds
    # ------------------------------------------------------------------

    async def push_portfolio_update(self, portfolio: Dict[str, Any]) -> bool:
        embed = DiscordEmbed(
            title="📈 Portfolio Update",
            color=self.COLOR_INFO,
        )
        embed.add_field("Equity", f"${portfolio.get('equity', 0):,.2f}")
        embed.add_field("Day P&L", f"{portfolio.get('day_pnl_pct', 0):+.2f}%")
        embed.add_field("Open Positions", str(portfolio.get("open_positions", 0)))
        embed.add_field("Win Rate", f"{portfolio.get('win_rate', 0):.1f}%")
        embed.set_footer("TradingAI Bot")
        return await self.send_webhook(embeds=[embed.to_dict()])

    async def push_daily_report(self, report: Dict[str, Any]) -> bool:
        embed = DiscordEmbed(
            title="📋 Daily Trading Report",
            description=report.get("summary", ""),
            color=self.COLOR_INFO,
        )
        embed.add_field("Signals Generated", str(report.get("signals_count", 0)))
        embed.add_field("Trades Executed", str(report.get("trades_count", 0)))
        embed.add_field("Win Rate", f"{report.get('win_rate', 0):.1f}%")
        embed.add_field("Total P&L", f"{report.get('total_pnl', 0):+.2f}%")
        embed.add_field("Best Trade", report.get("best_trade", "N/A"))
        embed.add_field("Worst Trade", report.get("worst_trade", "N/A"))
        embed.set_footer("TradingAI Bot — End of Day Report")
        return await self.send_webhook(embeds=[embed.to_dict()])

    async def push_alert(self, title: str, message: str, level: str = "info") -> bool:
        color_map = {
            "info": self.COLOR_INFO,
            "warn": self.COLOR_WARN,
            "buy": self.COLOR_BUY,
            "sell": self.COLOR_SELL,
        }
        embed = DiscordEmbed(
            title=f"🔔 {title}",
            description=message,
            color=color_map.get(level, self.COLOR_INFO),
        )
        return await self.send_webhook(embeds=[embed.to_dict()])

    # ------------------------------------------------------------------
    # Full interactive bot (requires discord.py)
    # ------------------------------------------------------------------

    async def run_interactive_bot(self):
        """
        Start the full interactive Discord bot with slash commands.
        Requires: pip install discord.py
        """
        try:
            import discord
            from discord import app_commands
            from discord.ext import commands
        except ImportError:
            self.logger.error(
                "discord.py not installed. Run: pip install discord.py"
            )
            return

        intents = discord.Intents.default()
        intents.message_content = True
        bot = commands.Bot(command_prefix="/", intents=intents)

        @bot.event
        async def on_ready():
            self.logger.info(f"Discord bot online as {bot.user}")
            try:
                synced = await bot.tree.sync()
                self.logger.info(f"Synced {len(synced)} commands")
            except Exception as e:
                self.logger.error(f"Sync error: {e}")

        @bot.tree.command(name="price", description="Get real-time price for a stock")
        async def cmd_price(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            # Fetch from Alpaca / Yahoo
            try:
                import yfinance as yf
                t = yf.Ticker(ticker.upper())
                info = t.info
                price = info.get("regularMarketPrice", info.get("currentPrice", 0))
                change = info.get("regularMarketChangePercent", 0)
                embed = discord.Embed(
                    title=f"💰 {ticker.upper()}",
                    color=0x00C853 if change >= 0 else 0xFF1744,
                )
                embed.add_field(name="Price", value=f"${price:.2f}")
                embed.add_field(name="Change", value=f"{change:+.2f}%")
                embed.add_field(name="Volume", value=f"{info.get('volume', 0):,}")
                await interaction.followup.send(embed=embed)
            except Exception as e:
                await interaction.followup.send(f"Error: {e}")

        @bot.tree.command(name="signals", description="Get latest AI trading signals")
        async def cmd_signals(interaction: discord.Interaction):
            await interaction.response.defer()
            await interaction.followup.send(
                "🤖 Generating signals... This may take a moment.",
            )

        @bot.tree.command(name="portfolio", description="View current portfolio")
        async def cmd_portfolio(interaction: discord.Interaction):
            await interaction.response.defer()
            embed = discord.Embed(title="📊 Portfolio", color=0x2979FF)
            embed.add_field(name="Status", value="Paper Trading Active")
            await interaction.followup.send(embed=embed)

        @bot.tree.command(name="backtest", description="Run a backtest")
        async def cmd_backtest(
            interaction: discord.Interaction,
            strategy: str,
            ticker: str,
            days: int = 252,
        ):
            await interaction.response.defer()
            await interaction.followup.send(
                f"📈 Running {strategy} backtest on {ticker.upper()} ({days} days)..."
            )

        if self.bot_token:
            await bot.start(self.bot_token)
        else:
            self.logger.error("No DISCORD_BOT_TOKEN configured")
