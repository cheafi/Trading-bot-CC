        # ==============================================================
        # /status
        # ==============================================================

        @bot.tree.command(name="status",
                          description="System status and connectivity")
        async def cmd_status(interaction: discord.Interaction):
            await interaction.response.defer()
            e = discord.Embed(title="📡 System Status", color=COLOR_SUCCESS)
            checks: List[tuple] = []
            # DB
            try:
                import asyncpg
                conn = await asyncpg.connect(
                    host=settings.postgres_host,
                    port=int(settings.postgres_port),
                    user=settings.postgres_user,
                    password=settings.postgres_password,
                    database=settings.postgres_db,
                )
                await conn.close()
                checks.append(("🗄️ Database", "✅ Connected"))
            except Exception:
                checks.append(("🗄️ Database", "❌ Offline"))
            # Redis
            try:
                import redis as rlib
                r = rlib.Redis(
                    host=settings.redis_host,
                    port=int(settings.redis_port),
                    password=settings.redis_password,
                    socket_timeout=2,
                )
                r.ping()
                checks.append(("📦 Redis", "✅ Connected"))
            except Exception:
                checks.append(("📦 Redis", "❌ Offline"))
            # Alpaca
            has_alpaca = bool(getattr(settings, "alpaca_api_key", ""))
            checks.append(("💹 Alpaca",
                           "✅ Configured" if has_alpaca else "⚠️ Not set"))
            # OpenAI / Azure
            has_ai = bool(
                getattr(settings, "openai_api_key", "")
                or getattr(settings, "azure_openai_endpoint", "")
            )
            checks.append(("🧠 AI/GPT",
                           "✅ Configured" if has_ai else "⚠️ Not set"))
            checks.append(("💬 Discord", f"✅ {bot.user}"))
            checks.append(("🌍 Markets", "US · HK · JP · Crypto"))
            for name, val in checks:
                e.add_field(name=name, value=val, inline=True)
