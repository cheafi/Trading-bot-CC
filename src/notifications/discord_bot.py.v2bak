        @bot.tree.command(name="movers",
                          description="Top gainers and losers today")
        async def cmd_movers(interaction: discord.Interaction):
            await interaction.response.defer()
            watchlist = [
                "AAPL", "MSFT", "GOOGL", "AMZN", "NVDA",
                "META", "TSLA", "AMD", "NFLX", "CRM",
                "COIN", "PLTR", "SOFI", "NIO", "RIVN",
                "MARA", "SQ", "SHOP", "ROKU", "SNAP",
            ]
            results = []
            for t in watchlist:
                data = await _fetch_stock(t)
                if "error" not in data:
                    results.append(data)
            results.sort(key=lambda x: x.get("change_pct", 0), reverse=True)
            e = discord.Embed(title="🔥 Top Movers Today", color=COLOR_INFO)
            gainers = "\n".join(
                f"**{r['ticker']}** ${r['price']:.2f} ({r['change_pct']:+.2f}%)"
                for r in results[:5]
            )
            losers = "\n".join(
                f"**{r['ticker']}** ${r['price']:.2f} ({r['change_pct']:+.2f}%)"
                for r in results[-5:]
            )
            e.add_field(name="🟢 Top Gainers", value=gainers or "N/A", inline=True)
            e.add_field(name="🔴 Top Losers", value=losers or "N/A", inline=True)
            await interaction.followup.send(embed=e)

