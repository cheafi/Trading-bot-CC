        @bot.tree.command(name="ai",
                          description="Full AI analysis for any stock")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_ai(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            d = await _fetch_stock(ticker)
            if "error" in d:
                await interaction.followup.send(f"❌ {d['error']}")
                return
            pct = d.get("change_pct", 0)
            price = d.get("price", 0)
            e = discord.Embed(
                title=f"🧠 AI Analysis — {d['ticker']}",
                description=f"**{d.get('name', '')}** | {d.get('sector', 'N/A')}",
                color=COLOR_PURPLE,
            )
            e.add_field(name="💰 Price", value=f"${price:.2f} ({pct:+.2f}%)")
            e.add_field(name="📊 Mkt Cap", value=_fmt_mcap(d.get("market_cap", 0)))
            yr_h = d.get("year_high", 0)
            yr_l = d.get("year_low", 0)
            if yr_h and yr_l and yr_h != yr_l:
                pos = (price - yr_l) / (yr_h - yr_l) * 100
                e.add_field(name="52W Position", value=f"{pos:.0f}% from low")
            pe = d.get("pe", 0)
            if pe:
                vlabel = ("Cheap" if pe < 15 else "Fair" if pe < 25
                          else "Expensive" if pe < 40 else "Very Expensive")
                e.add_field(name="Valuation", value=f"P/E {pe:.1f} ({vlabel})")
            # Recommendation
            if pct > 3:
                rec = "🟢 **BUY** — Strong momentum"
            elif pct > 0:
                rec = "🟡 **HOLD** — Mild upside"
            elif pct > -3:
                rec = "🟡 **HOLD** — Mild weakness"
            else:
                rec = "🔴 **CAUTION** — Selling pressure"
            e.add_field(name="🤖 AI Verdict", value=rec, inline=False)
            e.add_field(
                name="📝 Next Steps",
                value=(
                    f"`/analyze {ticker}` for technicals\n"
                    f"`/levels {ticker}` for support/resistance\n"
                    f"`/advise {ticker}` for trading advice"
                ),
                inline=False,
            )
            e.set_footer(text="TradingAI Pro • AI Analysis")
            await interaction.followup.send(embed=e)

        # ==============================================================
        # /analyze — technical analysis
        # ==============================================================

        @bot.tree.command(name="analyze",
                          description="Technical analysis with SMA, RSI, volume")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_analyze(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            try:
                import yfinance as yf
                t = yf.Ticker(ticker.upper())
                hist = t.history(period="3mo")
                if hist.empty:
                    await interaction.followup.send(f"❌ No data for {ticker.upper()}")
                    return
                close = hist["Close"]
                sma20 = close.rolling(20).mean().iloc[-1]
                sma50 = close.rolling(50).mean().iloc[-1]
                price = close.iloc[-1]
                vol = hist["Volume"].iloc[-1]
                avg_vol = hist["Volume"].rolling(20).mean().iloc[-1]
                # RSI
                delta = close.diff()
                gain = delta.where(delta > 0, 0).rolling(14).mean()
                loss = (-delta.where(delta < 0, 0)).rolling(14).mean()
                rs = gain.iloc[-1] / loss.iloc[-1] if loss.iloc[-1] != 0 else 0
                rsi = 100 - (100 / (1 + rs))

                e = discord.Embed(
                    title=f"📈 Technical Analysis — {ticker.upper()}",
                    color=COLOR_INFO,
                )
                e.add_field(name="Price", value=f"**${price:.2f}**")
                e.add_field(
                    name="SMA 20",
                    value=f"${sma20:.2f} {'(✅ Above)' if price > sma20 else '(❌ Below)'}",
                )
                e.add_field(
                    name="SMA 50",
                    value=f"${sma50:.2f} {'(✅ Above)' if price > sma50 else '(❌ Below)'}",
                )
                rsi_label = ("🟢 Oversold" if rsi < 30
                             else "🔴 Overbought" if rsi > 70
                             else "🟡 Neutral")
                e.add_field(name="RSI(14)", value=f"{rsi:.1f} {rsi_label}")
                rel_vol = vol / avg_vol if avg_vol else 0
                e.add_field(name="Rel Volume", value=f"{rel_vol:.1f}x avg")
                trend = ("🟢 Bullish" if price > sma20 > sma50
                         else "🔴 Bearish" if price < sma20 < sma50
                         else "🟡 Mixed")
                e.add_field(name="Trend", value=trend)
                e.set_footer(text="TradingAI Pro • Technical Analysis")
                await interaction.followup.send(embed=e)
            except Exception as exc:
                await interaction.followup.send(f"❌ {exc}")

        # ==============================================================
        # /advise — buy/hold/sell
        # ==============================================================

        @bot.tree.command(name="advise",
                          description="AI buy/hold/sell advice")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_advise(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            try:
                import yfinance as yf
                t = yf.Ticker(ticker.upper())
                hist = t.history(period="3mo")
                if hist.empty:
                    await interaction.followup.send(f"❌ No data for {ticker.upper()}")
                    return
                close = hist["Close"]
                price = close.iloc[-1]
                sma20 = close.rolling(20).mean().iloc[-1]
                sma50 = close.rolling(50).mean().iloc[-1]
                high_52 = close.max()
                low_52 = close.min()
                score = 50
                reasons = []
                if price > sma20:
                    score += 15; reasons.append("✅ Above 20-day MA")
                else:
                    score -= 15; reasons.append("❌ Below 20-day MA")
                if price > sma50:
                    score += 15; reasons.append("✅ Above 50-day MA")
                else:
                    score -= 15; reasons.append("❌ Below 50-day MA")
                dist_high = (high_52 - price) / high_52 * 100
                if dist_high < 5:
                    score += 10
                    reasons.append(f"🔥 Near 52W high ({dist_high:.1f}% away)")
                elif dist_high > 30:
                    score -= 10
                    reasons.append(f"⚠️ Far from 52W high ({dist_high:.1f}% away)")
                if score >= 70:
                    verdict = "🟢 **BUY**"; color = COLOR_BUY
                elif score >= 40:
                    verdict = "🟡 **HOLD**"; color = COLOR_WARN
                else:
                    verdict = "🔴 **SELL / AVOID**"; color = COLOR_SELL
                e = discord.Embed(
                    title=f"🤖 AI Advice — {ticker.upper()}",
                    description=f"Score: **{score}/100** → {verdict}",
                    color=color,
                )
                e.add_field(name="Current Price", value=f"${price:.2f}")
                e.add_field(name="52W Range", value=f"${low_52:.2f} — ${high_52:.2f}")
                e.add_field(name="📝 Reasons", value="\n".join(reasons), inline=False)
                e.set_footer(text="TradingAI Pro • Not financial advice")
                await interaction.followup.send(embed=e)
            except Exception as exc:
                await interaction.followup.send(f"❌ {exc}")

        # ==============================================================
        # /score
        # ==============================================================

        @bot.tree.command(name="score",
                          description="AI score 1-10 for a stock")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_score(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            d = await _fetch_stock(ticker)
            if "error" in d:
                await interaction.followup.send(f"❌ {d['error']}")
                return
            pct = d.get("change_pct", 0)
            pe = d.get("pe", 0)
            score = 5.0
            if pct > 2: score += 1.5
            elif pct > 0: score += 0.5
            elif pct < -2: score -= 1.5
            else: score -= 0.5
            if pe and 10 < pe < 25: score += 1
            elif pe and pe > 40: score -= 1
            score = max(1, min(10, score))
            stars = "⭐" * int(score) + "☆" * (10 - int(score))
            e = discord.Embed(
                title=f"🎯 AI Score — {d['ticker']}",
                description=f"**{score:.1f} / 10**\n{stars}",
                color=(COLOR_BUY if score >= 7
                       else COLOR_WARN if score >= 4
                       else COLOR_SELL),
            )
            e.add_field(name="Price", value=f"${d['price']:.2f} ({pct:+.2f}%)")
            e.set_footer(text="TradingAI Pro • AI Momentum Score")
            await interaction.followup.send(embed=e)

