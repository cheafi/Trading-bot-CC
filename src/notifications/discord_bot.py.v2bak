            await interaction.followup.send(embed=e)

        @bot.tree.command(name="risk",
                          description="Position sizing calculator")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_risk(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            d = await _fetch_stock(ticker)
            price = d.get("price", 0)
            account = 100_000
            risk_pct = 0.01
            stop_dist = price * 0.05
            shares = int((account * risk_pct) / stop_dist) if stop_dist else 0
            pos_val = shares * price
            e = discord.Embed(
                title=f"🛡️ Position Sizing — {ticker.upper()}",
                color=COLOR_INFO,
            )
            e.add_field(name="Price", value=f"${price:.2f}")
            e.add_field(name="Account", value=f"${account:,.0f}")
            e.add_field(name="Risk/Trade", value=f"{risk_pct*100:.1f}%")
            e.add_field(name="Stop Distance", value=f"${stop_dist:.2f} (5%)")
            e.add_field(name="🎯 Shares", value=f"**{shares}** (${pos_val:,.0f})")
            e.add_field(name="Max Loss", value=f"${account * risk_pct:,.0f}")
            await interaction.followup.send(embed=e)

        @bot.tree.command(name="stats",
                          description="Trading statistics summary")
        async def cmd_stats(interaction: discord.Interaction):
            await interaction.response.defer()
            e = discord.Embed(title="📊 Trading Statistics", color=COLOR_INFO)
            for k, v in [("Total Trades", "0"), ("Win Rate", "N/A"),
                         ("Profit Factor", "N/A"), ("Avg Win", "N/A"),
                         ("Avg Loss", "N/A"), ("Max Drawdown", "N/A")]:
                e.add_field(name=k, value=v)
            e.add_field(name="💡 Tip",
                        value="Start trading to build your stats!",
                        inline=False)
            await interaction.followup.send(embed=e)

