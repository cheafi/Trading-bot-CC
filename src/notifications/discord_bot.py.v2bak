        # /compare
        # ==============================================================

        @bot.tree.command(name="compare",
                          description="Compare two stocks side by side")
        @app_commands.describe(ticker1="First stock", ticker2="Second stock")
        async def cmd_compare(interaction: discord.Interaction,
                              ticker1: str, ticker2: str):
            await interaction.response.defer()
            d1 = await _fetch_stock(ticker1)
            d2 = await _fetch_stock(ticker2)
            e = discord.Embed(
                title=f"⚖️ {ticker1.upper()} vs {ticker2.upper()}",
                color=COLOR_PURPLE,
            )
            for label, key, fmt in [
                ("Price", "price", "${:.2f}"),
                ("Change", "change_pct", "{:+.2f}%"),
                ("Mkt Cap", "market_cap", "cap"),
                ("P/E", "pe", "{:.1f}"),
                ("Volume", "volume", "vol"),
            ]:
                v1, v2 = d1.get(key, 0) or 0, d2.get(key, 0) or 0
                if fmt == "cap": s1, s2 = _fmt_mcap(v1), _fmt_mcap(v2)
                elif fmt == "vol": s1, s2 = _fmt_vol(v1), _fmt_vol(v2)
                else:
                    s1 = fmt.format(v1) if v1 else "N/A"
                    s2 = fmt.format(v2) if v2 else "N/A"
                e.add_field(
                    name=label,
                    value=f"{ticker1.upper()}: {s1}\n{ticker2.upper()}: {s2}",
                    inline=True,
                )
            await interaction.followup.send(embed=e)

        # ==============================================================
        # /levels — support / resistance
        # ==============================================================

        @bot.tree.command(name="levels",
                          description="Key support and resistance levels")
        @app_commands.describe(ticker="Stock symbol")
        async def cmd_levels(interaction: discord.Interaction, ticker: str):
            await interaction.response.defer()
            try:
                import yfinance as yf
                t = yf.Ticker(ticker.upper())
                hist = t.history(period="6mo")
                if hist.empty:
                    await interaction.followup.send(f"❌ No data for {ticker.upper()}")
                    return
                close = hist["Close"]
                high = hist["High"]
                low = hist["Low"]
                price = close.iloc[-1]
                sma20 = close.rolling(20).mean().iloc[-1]
                sma50 = close.rolling(50).mean().iloc[-1]
                r1 = high.rolling(20).max().iloc[-1]
                s1 = low.rolling(20).min().iloc[-1]
                r2 = high.max()
                s2 = low.min()
                e = discord.Embed(
                    title=f"📏 Support / Resistance — {ticker.upper()}",
                    description=f"Current: **${price:.2f}**",
                    color=COLOR_INFO,
                )
                for name, val in [
                    ("🔴 Resistance 2 (6mo high)", f"${r2:.2f}"),
                    ("🟠 Resistance 1 (20d high)", f"${r1:.2f}"),
                    ("➖ SMA 20", f"${sma20:.2f}"),
                    ("➖ SMA 50", f"${sma50:.2f}"),
                    ("🟢 Support 1 (20d low)", f"${s1:.2f}"),
                    ("🟢 Support 2 (6mo low)", f"${s2:.2f}"),
                ]:
                    e.add_field(name=name, value=val, inline=False)
                await interaction.followup.send(embed=e)
            except Exception as exc:
                await interaction.followup.send(f"❌ {exc}")

