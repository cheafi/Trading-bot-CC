        # ==============================================================
        # BOT EVENTS
        # ==============================================================

        @bot.event
        async def on_ready():
            logger.info(f"✅ Discord bot online as {bot.user}")
            print(f"✅ TradingAI Bot connected as {bot.user}")
            print(f"   Servers: {', '.join(g.name for g in bot.guilds)}")
            for guild in bot.guilds:
                await setup_channels(guild)
            # Send welcome
            wch = self._channels.get("welcome")
            if wch:
                await wch.send(embed=_welcome_embed())
            # Sync slash commands
            try:
                synced = await bot.tree.sync()
                logger.info(f"Synced {len(synced)} slash commands")
                print(f"   Synced {len(synced)} slash commands")
            except Exception as exc:
                logger.error(f"Slash command sync error: {exc}")

        @bot.event
        async def on_guild_join(guild: discord.Guild):
            await setup_channels(guild)
            wch = self._channels.get("welcome")
            if wch:
                await wch.send(embed=_welcome_embed())

