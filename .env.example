# TradingAI Bot Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=tradingai
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tradingai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# MARKET DATA APIS
# =============================================================================
# Polygon.io (recommended for US equities)
POLYGON_API_KEY=your_polygon_api_key

# Alpaca (alternative / paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# IEX Cloud (alternative)
IEX_API_KEY=

# =============================================================================
# NEWS APIS
# =============================================================================
NEWSAPI_KEY=your_newsapi_key
BENZINGA_API_KEY=
FINNHUB_API_KEY=

# =============================================================================
# SOCIAL MEDIA APIS (ToS-compliant usage only)
# =============================================================================
# X (Twitter) API v2
X_BEARER_TOKEN=

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingAI Bot/1.0

# =============================================================================
# AI / LLM - Azure OpenAI (Recommended)
# =============================================================================
# Azure AD Service Principal credentials
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2026-01-15-preview

# =============================================================================
# AI / LLM - Standard OpenAI (Alternative)
# =============================================================================
# Leave Azure fields empty and use this instead:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_MINI=gpt-5.2-mini

# =============================================================================
# NOTIFICATIONS - Telegram (Primary)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# BROKERS - Futu (富途)
# =============================================================================
# Futu OpenD Gateway connection
# Download OpenD from: https://www.futunn.com/en/download/openAPI
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_PASSWORD=your_trade_password
FUTU_UNLOCK_PIN=your_unlock_pin
FUTU_RSA_FILE=

# =============================================================================
# BROKERS - Interactive Brokers (IB)
# =============================================================================
# IB TWS or IB Gateway connection
# Port 7497 for TWS, 4001 for IB Gateway
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
IB_ACCOUNT=

# =============================================================================
# BROKERS - MetaTrader 5 (Forex/CFD/Crypto) — Windows Only
# =============================================================================
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=MetaQuotes-Demo
MT5_PATH=

# =============================================================================
# NOTIFICATIONS - Discord Bot
# =============================================================================
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_NAME=Trading CC

# =============================================================================
# NOTIFICATIONS - Slack (Alternative)
# =============================================================================
SLACK_WEBHOOK_URL=

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=

# =============================================================================
# S3-COMPATIBLE STORAGE (Optional)
# =============================================================================
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET=

# =============================================================================
# API SECURITY
# =============================================================================
API_SECRET_KEY=generate_a_random_64_char_string

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# =============================================================================
# DEVELOPMENT
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
JUPYTER_TOKEN=tradingai
PGADMIN_EMAIL=admin@tradingai.local
PGADMIN_PASSWORD=admin
