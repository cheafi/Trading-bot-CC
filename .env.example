# ============================================================================
# CC — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control.
# ⚠️  Use least-privilege credentials everywhere.
# ⚠️  Rotate secrets periodically.
# ============================================================================

# --- App -------------------------------------------------------------------
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# --- Discord (PRIMARY interface) -------------------------------------------
DISCORD_BOT_TOKEN=             # Bot → Settings → Token (never share)
DISCORD_GUILD_ID=              # Right-click server → Copy Server ID
DISCORD_ALERT_CHANNEL_ID=      # Channel for trade signals
DISCORD_NEWS_CHANNEL_ID=       # Channel for market news
DISCORD_RISK_CHANNEL_ID=       # Channel for risk escalation alerts
DISCORD_LOG_CHANNEL_ID=        # Channel for system/operational logs
# Permissions needed: Send Messages, Embed Links, Read Message History
# Do NOT grant Administrator to the bot.

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://cc_user:CHANGE_ME@localhost:5432/tradingai
# Use a dedicated app user, NOT the superuser.

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- OpenAI / LLM ----------------------------------------------------------
OPENAI_API_KEY=                # Required for AI-enhanced signal narratives
OPENAI_MODEL=gpt-4o-mini      # gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# No admin/fine-tuning access needed — standard API key is sufficient.

# --- Broker: Paper (default — no key needed) --------------------------------
BROKER=paper

# --- Broker: Alpaca ---------------------------------------------------------
# BROKER=alpaca
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading
# # For live: https://api.alpaca.markets (use with extreme caution)

# --- Broker: Futu (富途) ----------------------------------------------------
# BROKER=futu
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111
# # Requires FutuOpenD running locally. See docs/SETUP_GUIDE.md for details.
# # Never expose FutuOpenD port to the public internet.

# --- Broker: Interactive Brokers --------------------------------------------
# BROKER=ibkr
# IB_HOST=127.0.0.1
# IB_PORT=7497               # 7497=paper, 7496=live
# IB_CLIENT_ID=1
# # Requires TWS or IB Gateway running. Paper mode strongly recommended first.

# --- Broker: MetaTrader 5 ---------------------------------------------------
# BROKER=mt5
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=
# # Windows only. Demo account recommended first.

# --- Market Data ------------------------------------------------------------
# MARKET_DATA_SOURCE=yfinance   # yfinance (free) | alpaca | polygon
# POLYGON_API_KEY=              # Optional: for Polygon.io real-time data
# FINNHUB_API_KEY=              # Optional: for news/sentiment

# --- Monitoring (optional) --------------------------------------------------
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME
# PGADMIN_EMAIL=admin@example.com
# PGADMIN_PASSWORD=CHANGE_ME
# SENTRY_DSN=                   # Optional: error tracking

# ============================================================================
# ⚠️  REMINDER: Change ALL default passwords before any deployment.
# ⚠️  Paper/sandbox mode FIRST. Live trading at your own risk.
# ============================================================================
